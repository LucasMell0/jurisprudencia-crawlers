# Postgres do Autosfy (db01) — mesmas tabelas jurisprudence_* que o
# crawler do Jusfy usa (ver adfy/sql/016 e 017). Use a role isolada
# jurisprudence_crawler (só SELECT/INSERT/UPDATE nas tabelas de
# jurisprudência), não a autosfy_app completa.
DATABASE_URL=postgresql://jurisprudence_crawler:SENHA@192.168.31.68:5432/autosfy_db
DB_POOL_MAX=10

# Deixar sem definir usa os defaults conservadores do código (concorrência
# 1, 3s entre requisições) — só sobrescreva com valores MAIORES que isso
# se tiver confirmado com o Falcão que um ritmo mais rápido é aceitável.
# Aumentar sem confirmar arrisca bloqueio (ver README/histórico de commits).
# FALCAO_CONCURRENCY=1
# FALCAO_REQUEST_DELAY_MS=3000
